<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Face_Recognition.RegisterPage"
             Title="Register"
             BackgroundColor="#214B3B">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#173B2F" Offset="0.0" />
                <GradientStop Color="#214B3B" Offset="0.5" />
                <GradientStop Color="#0F2D24" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse x:Name="RegisterCircle"
                 WidthRequest="280"
                 HeightRequest="280"
                 Fill="#9FD8CB"
                 Opacity="0.12"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="-100,-90,0,0" />

        <Ellipse WidthRequest="310"
                 HeightRequest="310"
                 Fill="#8ED1C6"
                 Opacity="0.10"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,-110,-120" />

        <Grid Padding="40">

            <Border StrokeThickness="0"
                    BackgroundColor="#285A46"
                    StrokeShape="RoundRectangle 34"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="1180"
                    HeightRequest="650">

                <Grid ColumnDefinitions="0.70*,1.30*">

                    <Border Grid.Column="0"
                            BackgroundColor="#F4FAF8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 34">

                        <Grid Padding="34">

                            <VerticalStackLayout HorizontalOptions="Start"
                                                 VerticalOptions="Start"
                                                 Spacing="2">

                                <Label Text="SIAGA"
                                       FontSize="25"
                                       FontAttributes="Bold"
                                       TextColor="#285A46" />

                                <Label Text="Dashboard Kebencanaan"
                                       FontSize="13"
                                       TextColor="#5B7F73" />

                            </VerticalStackLayout>

                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="7">

                                <Label Text="REGISTER"
                                       FontSize="38"
                                       FontAttributes="Bold"
                                       TextColor="#285A46"
                                       HorizontalOptions="Center" />

                                <Label Text="Registrasi Akun"
                                       FontSize="21"
                                       FontAttributes="Bold"
                                       TextColor="#285A46"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center" />

                                <Label Text="Buat akun, pilih role, lalu isi data tambahan sesuai peran pengguna."
                                       FontSize="13"
                                       TextColor="#6D8B82"
                                       HorizontalTextAlignment="Center"
                                       WidthRequest="280" />

                            </VerticalStackLayout>

                        </Grid>

                    </Border>

                    <ScrollView Grid.Column="1"
                                BackgroundColor="#285A46">

                        <VerticalStackLayout Padding="62,28"
                                             Spacing="8"
                                             MaximumWidthRequest="500">

                            <Label Text="Register"
                                   FontSize="37"
                                   FontAttributes="Bold"
                                   TextColor="White" />

                            <Label Text="Buat akun untuk mulai menggunakan sistem"
                                   FontSize="14"
                                   TextColor="#CDE5DE"
                                   Margin="0,0,0,8" />

                            <Label Text="Username"
                                   TextColor="White"
                                   FontSize="14" />

                            <Border BackgroundColor="#1F3F32"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="44">

                                <Entry x:Name="RegisterUsernameEntry"
                                       Placeholder="Enter your username"
                                       TextColor="White"
                                       PlaceholderColor="#A7C6BD"
                                       BackgroundColor="Transparent"
                                       Margin="14,0" />

                            </Border>

                            <Label Text="Password"
                                   TextColor="White"
                                   FontSize="14"
                                   Margin="0,2,0,0" />

                            <Border BackgroundColor="#1F3F32"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="44">

                                <Entry x:Name="RegisterPasswordEntry"
                                       Placeholder="Enter your password"
                                       IsPassword="True"
                                       TextColor="White"
                                       PlaceholderColor="#A7C6BD"
                                       BackgroundColor="Transparent"
                                       Margin="14,0" />

                            </Border>

                            <Label Text="Confirm Password"
                                   TextColor="White"
                                   FontSize="14"
                                   Margin="0,2,0,0" />

                            <Border BackgroundColor="#1F3F32"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="44">

                                <Entry x:Name="ConfirmPasswordEntry"
                                       Placeholder="Confirm your password"
                                       IsPassword="True"
                                       TextColor="White"
                                       PlaceholderColor="#A7C6BD"
                                       BackgroundColor="Transparent"
                                       Margin="14,0" />

                            </Border>

                            <Label Text="Role"
                                   TextColor="White"
                                   FontSize="14"
                                   Margin="0,2,0,0" />

                            <Border BackgroundColor="#1F3F32"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    HeightRequest="58"
                                    Padding="14,0">

                                <Picker x:Name="RegisterRolePicker"
                                        Title="Pilih Role"
                                        TitleColor="#A7C6BD"
                                        TextColor="White"
                                        BackgroundColor="Transparent"
                                        HeightRequest="58"
                                        VerticalOptions="Center"
                                        SelectedIndexChanged="OnRegisterRoleChanged">

                                    <Picker.Items>
                                        <x:String>Masyarakat</x:String>
                                        <x:String>Operator</x:String>
                                    </Picker.Items>

                                </Picker>

                            </Border>

                            <Border x:Name="MasyarakatFormPanel"
                                    IsVisible="False"
                                    BackgroundColor="#214B3B"
                                    Stroke="#8ED1C6"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="18"
                                    Margin="0,14,0,0">

                                <VerticalStackLayout Spacing="8">

                                    <Label Text="Data Masyarakat"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White" />

                                    <Label Text="Nama Lengkap"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="MasyarakatFullNameEntry"
                                               Placeholder="Masukkan nama lengkap"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <Label Text="Usia"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="MasyarakatAgeEntry"
                                               Placeholder="Contoh: 20"
                                               Keyboard="Numeric"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <Label Text="Nomor Telepon"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="MasyarakatPhoneEntry"
                                               Placeholder="Contoh: 081234567890"
                                               Keyboard="Telephone"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <Label Text="Alamat / Domisili"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="MasyarakatAddressEntry"
                                               Placeholder="Masukkan alamat atau domisili"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <HorizontalStackLayout Spacing="8">

                                        <Label Text="Wilayah Pantauan"
                                               TextColor="White"
                                               FontSize="13"
                                               VerticalOptions="Center" />

                                        <Button Text="i"
                                                Clicked="OnMonitoringAreaInfoClicked"
                                                BackgroundColor="#8ED1C6"
                                                TextColor="#173B2F"
                                                CornerRadius="12"
                                                WidthRequest="24"
                                                HeightRequest="24"
                                                FontSize="12"
                                                Padding="0" />

                                    </HorizontalStackLayout>

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="MasyarakatMonitoringAreaEntry"
                                               Placeholder="Contoh: Keputih, Sukolilo"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                </VerticalStackLayout>

                            </Border>

                            <Border x:Name="OperatorFormPanel"
                                    IsVisible="False"
                                    BackgroundColor="#214B3B"
                                    Stroke="#8ED1C6"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="18"
                                    Margin="0,14,0,0">

                                <VerticalStackLayout Spacing="8">

                                    <Label Text="Data Operator"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White" />

                                    <Label Text="Nama Lengkap"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="OperatorFullNameEntry"
                                               Placeholder="Masukkan nama lengkap"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <Label Text="ID Operator"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="OperatorIdEntry"
                                               Placeholder="Contoh: OP001"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <Label Text="Instansi / Unit"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="OperatorInstitutionEntry"
                                               Placeholder="Contoh: Pos Pantau Banjir"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <HorizontalStackLayout Spacing="8">

                                        <Label Text="Wilayah Tugas"
                                               TextColor="White"
                                               FontSize="13"
                                               VerticalOptions="Center" />

                                        <Button Text="i"
                                                Clicked="OnDutyAreaInfoClicked"
                                                BackgroundColor="#8ED1C6"
                                                TextColor="#173B2F"
                                                CornerRadius="12"
                                                WidthRequest="24"
                                                HeightRequest="24"
                                                FontSize="12"
                                                Padding="0" />

                                    </HorizontalStackLayout>

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="OperatorDutyAreaEntry"
                                               Placeholder="Contoh: Surabaya Timur"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <Label Text="Nomor Telepon"
                                           TextColor="White"
                                           FontSize="13" />

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="OperatorPhoneEntry"
                                               Placeholder="Contoh: 081234567890"
                                               Keyboard="Telephone"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                    <HorizontalStackLayout Spacing="8">

                                        <Label Text="Kode Akses Operator"
                                               TextColor="White"
                                               FontSize="13"
                                               VerticalOptions="Center" />

                                        <Button Text="i"
                                                Clicked="OnOperatorAccessInfoClicked"
                                                BackgroundColor="#8ED1C6"
                                                TextColor="#173B2F"
                                                CornerRadius="12"
                                                WidthRequest="24"
                                                HeightRequest="24"
                                                FontSize="12"
                                                Padding="0" />

                                    </HorizontalStackLayout>

                                    <Border BackgroundColor="#1F3F32"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            HeightRequest="42">

                                        <Entry x:Name="OperatorAccessCodeEntry"
                                               Placeholder="Masukkan kode akses operator"
                                               IsPassword="True"
                                               TextColor="White"
                                               PlaceholderColor="#A7C6BD"
                                               BackgroundColor="Transparent"
                                               Margin="12,0" />

                                    </Border>

                                </VerticalStackLayout>

                            </Border>

                            <Button Text="Register"
                                    Clicked="OnRegisterClicked"
                                    BackgroundColor="#8ED1C6"
                                    TextColor="#173B2F"
                                    CornerRadius="22"
                                    HeightRequest="45"
                                    FontAttributes="Bold"
                                    Margin="0,12,0,0" />

                            <Label Text="Sudah punya akun?"
                                   TextColor="#E7F5F1"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   Margin="0,4,0,0" />

                            <Button Text="Kembali ke Login"
                                    Clicked="OnBackToLoginClicked"
                                    BackgroundColor="Transparent"
                                    BorderColor="#8ED1C6"
                                    BorderWidth="1"
                                    TextColor="#B7E4DA"
                                    CornerRadius="20"
                                    HeightRequest="40"
                                    FontAttributes="Bold" />

                        </VerticalStackLayout>

                    </ScrollView>

                </Grid>

            </Border>

        </Grid>

        <Button Text="?  Ada masalah? Tanyakan saja"
                Clicked="OnRegisterHelpToggleClicked"
                BackgroundColor="#8ED1C6"
                TextColor="#173B2F"
                CornerRadius="24"
                HeightRequest="46"
                WidthRequest="250"
                FontAttributes="Bold"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,36,26" />

        <Border x:Name="RegisterHelpPanel"
                IsVisible="False"
                BackgroundColor="#F4FAF8"
                Stroke="#8ED1C6"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="16"
                WidthRequest="500"
                HeightRequest="590"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,36,82">

            <VerticalStackLayout Spacing="9">

                <Grid ColumnDefinitions="*,38">

                    <Label Text="Bantuan Registrasi"
                           FontSize="19"
                           FontAttributes="Bold"
                           TextColor="#173B2F"
                           VerticalOptions="Center" />

                    <Button Grid.Column="1"
                            Text="X"
                            Clicked="OnRegisterHelpToggleClicked"
                            BackgroundColor="Transparent"
                            TextColor="#173B2F"
                            FontSize="18"
                            Padding="0" />

                </Grid>

                <Label Text="Ketik pertanyaan atau klik pertanyaan biru di bawah ini."
                       FontSize="12"
                       TextColor="#6D8B82" />

                <Grid ColumnDefinitions="*,95"
                      ColumnSpacing="8">

                    <Entry x:Name="RegisterHelpEntry"
                           Grid.Column="0"
                           Placeholder="Contoh: registrasi wajah gagal"
                           PlaceholderColor="#8AA69D"
                           TextColor="#173B2F"
                           BackgroundColor="#EAF3F0"
                           Completed="OnRegisterHelpSendClicked"
                           HeightRequest="40" />

                    <Button Grid.Column="1"
                            Text="Kirim"
                            Clicked="OnRegisterHelpSendClicked"
                            BackgroundColor="#285A46"
                            TextColor="White"
                            CornerRadius="16"
                            HeightRequest="40"
                            FontAttributes="Bold" />

                </Grid>

                <FlexLayout Wrap="Wrap"
                            Direction="Row"
                            AlignItems="Start"
                            JustifyContent="Start"
                            HeightRequest="102">

                    <Button Text="Cara registrasi?"
                            CommandParameter="Cara registrasi?"
                            Clicked="OnRegisterQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Registrasi wajah gagal?"
                            CommandParameter="Registrasi wajah gagal?"
                            Clicked="OnRegisterQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Password tidak sama?"
                            CommandParameter="Password tidak sama?"
                            Clicked="OnRegisterQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Username sudah terdaftar?"
                            CommandParameter="Username sudah terdaftar?"
                            Clicked="OnRegisterQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Kamera tidak terbuka?"
                            CommandParameter="Kamera tidak terbuka?"
                            Clicked="OnRegisterQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Sudah registrasi?"
                            CommandParameter="Sudah registrasi?"
                            Clicked="OnRegisterQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                </FlexLayout>

                <Border BackgroundColor="#FFFFFF"
                        Stroke="#DCEDEA"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="12"
                        HeightRequest="280">

                    <ScrollView VerticalScrollBarVisibility="Always">

                        <VerticalStackLayout Spacing="6">

                            <Label x:Name="RegisterHelpTitleLabel"
                                   Text="Belum ada pertanyaan"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#173B2F" />

                            <Label x:Name="RegisterHelpMessageLabel"
                                   Text="Hasil bantuan akan tampil di sini."
                                   FontSize="12"
                                   TextColor="#285A46"
                                   LineBreakMode="WordWrap" />

                            <Button x:Name="RegisterHelpActionButton"
                                    IsVisible="False"
                                    Text="Kembali ke Login"
                                    Clicked="OnRegisterHelpActionClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="#2563EB"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Start"
                                    Padding="0" />

                        </VerticalStackLayout>

                    </ScrollView>

                </Border>

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>
