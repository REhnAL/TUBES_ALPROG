<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Face_Recognition.LoginPage"
             Title="Login"
             BackgroundColor="#214B3B">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#173B2F" Offset="0.0" />
                <GradientStop Color="#214B3B" Offset="0.5" />
                <GradientStop Color="#0F2D24" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse x:Name="CircleOne"
                 WidthRequest="280"
                 HeightRequest="280"
                 Fill="#9FD8CB"
                 Opacity="0.12"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="-100,-90,0,0" />

        <Ellipse x:Name="CircleTwo"
                 WidthRequest="310"
                 HeightRequest="310"
                 Fill="#8ED1C6"
                 Opacity="0.10"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,-110,-120" />

        <Grid Padding="40">

            <Border StrokeThickness="0"
                    BackgroundColor="#285A46"
                    StrokeShape="RoundRectangle 34"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="1180"
                    HeightRequest="650">

                <Grid ColumnDefinitions="0.75*,1.25*">

                    <Border Grid.Column="0"
                            BackgroundColor="#F4FAF8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 34">

                        <Grid Padding="34">

                            <VerticalStackLayout HorizontalOptions="Start"
                                                 VerticalOptions="Start"
                                                 Spacing="2">

                                <Label Text="SIAGA"
                                       FontSize="25"
                                       FontAttributes="Bold"
                                       TextColor="#285A46" />

                                <Label Text="Dashboard Kebencanaan"
                                       FontSize="13"
                                       TextColor="#5B7F73" />

                            </VerticalStackLayout>

                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="7">

                                <Label Text="🌳"
                                       FontSize="78"
                                       HorizontalOptions="Center" />

                                <Label Text="Sistem Informasi Kebencanaan"
                                       FontSize="21"
                                       FontAttributes="Bold"
                                       TextColor="#285A46"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center" />

                                <Label Text="Login, verifikasi wajah, dan dashboard sesuai role pengguna."
                                       FontSize="13"
                                       TextColor="#6D8B82"
                                       HorizontalTextAlignment="Center"
                                       WidthRequest="300" />

                            </VerticalStackLayout>

                            <HorizontalStackLayout HorizontalOptions="Start"
                                                   VerticalOptions="End"
                                                   Spacing="14">

                                <Label Text="👤"
                                       FontSize="28" />

                                <Label Text="🏠"
                                       FontSize="28" />

                                <Label Text="🚨"
                                       FontSize="28" />

                            </HorizontalStackLayout>

                        </Grid>

                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Padding="76,74"
                                         Spacing="10"
                                         MaximumWidthRequest="520">

                        <Label Text="Login"
                               FontSize="38"
                               FontAttributes="Bold"
                               TextColor="White" />

                        <Label Text="Masuk untuk melanjutkan ke sistem"
                               FontSize="14"
                               TextColor="#CDE5DE"
                               Margin="0,0,0,8" />

                        <Label Text="Username"
                               TextColor="White"
                               FontSize="14" />

                        <Border BackgroundColor="#1F3F32"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                HeightRequest="44">

                            <Entry x:Name="LoginUsernameEntry"
                                   Placeholder="Enter your username"
                                   TextColor="White"
                                   PlaceholderColor="#A7C6BD"
                                   BackgroundColor="Transparent"
                                   Margin="14,0" />

                        </Border>

                        <Label Text="Password"
                               TextColor="White"
                               FontSize="14"
                               Margin="0,2,0,0" />

                        <Border BackgroundColor="#1F3F32"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                HeightRequest="44">

                            <Entry x:Name="LoginPasswordEntry"
                                   Placeholder="Enter your password"
                                   IsPassword="True"
                                   TextColor="White"
                                   PlaceholderColor="#A7C6BD"
                                   BackgroundColor="Transparent"
                                   Margin="14,0" />

                        </Border>

                        <Label Text="Role"
                               TextColor="White"
                               FontSize="14"
                               Margin="0,2,0,0" />

                        <Border BackgroundColor="#1F3F32"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                HeightRequest="58"
                                Padding="14,0">

                            <Picker x:Name="LoginRolePicker"
                                    Title="Pilih Role"
                                    TitleColor="#A7C6BD"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    HeightRequest="58"
                                    VerticalOptions="Center">

                                <Picker.Items>
                                    <x:String>Masyarakat</x:String>
                                    <x:String>Operator</x:String>
                                </Picker.Items>

                            </Picker>

                        </Border>

                        <Button Text="Login"
                                Clicked="OnLoginClicked"
                                BackgroundColor="#8ED1C6"
                                TextColor="#173B2F"
                                CornerRadius="22"
                                HeightRequest="45"
                                FontAttributes="Bold"
                                Margin="0,10,0,0" />

                        <Label Text="Belum punya akun?"
                               TextColor="#E7F5F1"
                               FontSize="13"
                               HorizontalOptions="Center"
                               Margin="0,4,0,0" />

                        <Button Text="Register Sekarang"
                                Clicked="OnGoToRegisterClicked"
                                BackgroundColor="Transparent"
                                BorderColor="#8ED1C6"
                                BorderWidth="1"
                                TextColor="#B7E4DA"
                                CornerRadius="20"
                                HeightRequest="40"
                                FontAttributes="Bold" />

                    </VerticalStackLayout>

                </Grid>

            </Border>

        </Grid>

        <Button Text="?  Ada masalah? Tanyakan saja"
                Clicked="OnLoginHelpToggleClicked"
                BackgroundColor="#8ED1C6"
                TextColor="#173B2F"
                CornerRadius="24"
                HeightRequest="46"
                WidthRequest="250"
                FontAttributes="Bold"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,36,26" />

        <Border x:Name="LoginHelpPanel"
                IsVisible="False"
                BackgroundColor="#F4FAF8"
                Stroke="#8ED1C6"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="16"
                WidthRequest="500"
                HeightRequest="590"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,36,82">

            <VerticalStackLayout Spacing="9">

                <Grid ColumnDefinitions="*,38">

                    <Label Text="Bantuan Login"
                           FontSize="19"
                           FontAttributes="Bold"
                           TextColor="#173B2F"
                           VerticalOptions="Center" />

                    <Button Grid.Column="1"
                            Text="X"
                            Clicked="OnLoginHelpToggleClicked"
                            BackgroundColor="Transparent"
                            TextColor="#173B2F"
                            FontSize="18"
                            Padding="0" />

                </Grid>

                <Label Text="Ketik pertanyaan atau klik pertanyaan biru di bawah ini."
                       FontSize="12"
                       TextColor="#6D8B82" />

                <Grid ColumnDefinitions="*,95"
                      ColumnSpacing="8">

                    <Entry x:Name="LoginHelpEntry"
                           Grid.Column="0"
                           Placeholder="Contoh: kenapa saya tidak bisa login?"
                           PlaceholderColor="#8AA69D"
                           TextColor="#173B2F"
                           BackgroundColor="#EAF3F0"
                           Completed="OnLoginHelpSendClicked"
                           HeightRequest="40" />

                    <Button Grid.Column="1"
                            Text="Kirim"
                            Clicked="OnLoginHelpSendClicked"
                            BackgroundColor="#285A46"
                            TextColor="White"
                            CornerRadius="16"
                            HeightRequest="40"
                            FontAttributes="Bold" />

                </Grid>

                <FlexLayout Wrap="Wrap"
                            Direction="Row"
                            AlignItems="Start"
                            JustifyContent="Start"
                            HeightRequest="102">

                    <Button Text="Wajah tidak terdeteksi?"
                            CommandParameter="Wajah tidak terdeteksi?"
                            Clicked="OnLoginQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Tidak bisa login?"
                            CommandParameter="Tidak bisa login?"
                            Clicked="OnLoginQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Belum punya akun?"
                            CommandParameter="Belum punya akun?"
                            Clicked="OnLoginQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Kamera tidak terbuka?"
                            CommandParameter="Kamera tidak terbuka?"
                            Clicked="OnLoginQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                    <Button Text="Lupa password?"
                            CommandParameter="Lupa password?"
                            Clicked="OnLoginQuickQuestionClicked"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            FontSize="12"
                            Padding="0"
                            Margin="0,0,14,0" />

                </FlexLayout>

                <Border BackgroundColor="#FFFFFF"
                        Stroke="#DCEDEA"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="12"
                        HeightRequest="280">

                    <ScrollView VerticalScrollBarVisibility="Always">

                        <VerticalStackLayout Spacing="6">

                            <Label x:Name="LoginHelpTitleLabel"
                                   Text="Belum ada pertanyaan"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#173B2F" />

                            <Label x:Name="LoginHelpMessageLabel"
                                   Text="Hasil bantuan akan tampil di sini."
                                   FontSize="12"
                                   TextColor="#285A46"
                                   LineBreakMode="WordWrap" />

                            <Button x:Name="LoginHelpActionButton"
                                    IsVisible="False"
                                    Text="Register di sini"
                                    Clicked="OnLoginHelpActionClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="#2563EB"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Start"
                                    Padding="0" />

                        </VerticalStackLayout>

                    </ScrollView>

                </Border>

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentPage>
